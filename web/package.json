{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "biome ci . && bun run typecheck && bun run test:unit && bun run build",
    "check:full": "bun run check && bun run test:e2e",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "test": "bun run test:unit",
    "test:unit": "bun test --preload ./test/setup-dom.ts ./test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "fixtures": "bun run fixtures/server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.4",
    "@happy-dom/global-registrator": "^20.11.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "typescript": "~6",
    "vite": "^8"
  }
}
