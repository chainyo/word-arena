{
  "kind": "word_arena_agent_budget_contract",
  "capability_schema_version": 1,
  "telemetry_schema_version": 1,
  "dimensions": [
    "wall_time",
    "cpu_time",
    "memory",
    "network_bytes",
    "input_tokens",
    "output_tokens",
    "attempts",
    "tool_calls",
    "output_bytes",
    "cost"
  ],
  "status": ["hard", "conditional", "unenforced"],
  "unenforced_policy": ["allow_reported", "fail_closed"],
  "hard_v1": ["wall_time", "attempts", "tool_calls", "output_bytes"],
  "conditional_v1": ["input_tokens", "output_tokens", "cost"],
  "platform_dependent_v1": ["cpu_time", "memory", "network_bytes"],
  "limit_event_fields": [
    "sequence",
    "at_unix_ms",
    "dimension",
    "limit",
    "observed",
    "source"
  ],
  "termination": "complete_process_group"
}
